# Copy this file to .env and fill in your keys.
HELIUS_API_KEY=your_helius_api_key_here
BIRDEYE_API_KEY=your_birdeye_api_key_here

LOOKBACK_HOURS=48
MIN_WIN_RATE=0.50
MIN_TRADES=10
MIN_AVG_BUY_SOL=0.5
TOP_WALLETS=100
MAX_WALLETS_TO_SCORE=200
SLEEP_SECONDS=0.15
OUTPUT_FILE=output/top_wallets.csv

# Optional: run without API keys to verify install/output.
# DEMO_MODE=true

# Optional: use CSV mode instead of API scan.
# INPUT_CSV=sniper-wallets.csv

# Optional: comma-separated fallback wallets if discovery fails.
# SEED_WALLETS=wallet1,wallet2,wallet3

# Optional: comma-separated token mints for Birdeye wallet discovery.
# DISCOVERY_TOKEN_MINTS=So11111111111111111111111111111111111111112

# Optional: use DEX Screener to discover fresh Solana token mints.
# DEXSCREENER_DISCOVERY=true
# DEXSCREENER_MAX_TOKENS=25
# DEXSCREENER_TOKEN_PROFILE_URL=https://api.dexscreener.com/token-profiles/latest/v1
# You can test a newer route by overriding the URL/path, for example:
# DEXSCREENER_TOKEN_PROFILE_URL=/token-profiles/recent-updates/v1
